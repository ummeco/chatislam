# chatislam/web — environment variables
# Copy to .env.local and fill in values
# Run: next dev --port 3042

# Hasura GraphQL endpoint (per-app CORS-restricted)
NEXT_PUBLIC_HASURA_URL=https://api.chatislam.local.nself.org:8543/v1/graphql

# Hasura Auth endpoint (shared SSO across all apps)
NEXT_PUBLIC_AUTH_URL=https://auth.local.nself.org:8543

# Auth client URL scoped to THIS app — tells Hasura Auth where to redirect after email confirm.
# Prod: sourced from vault AUTH_CLIENT_URL_CHATISLAM.
AUTH_CLIENT_URL=https://chatislam.org

# Public base URL for this app
NEXT_PUBLIC_BASE_URL=https://www.chatislam.local.nself.org:8543

# Secret for validating Remote Schema requests from Hasura
REMOTE_SCHEMA_SECRET=

# AI (Anthropic Claude — chat and Q&A; direct API in P3 per D-P3-44)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Rate limiting — Redis (T0-04-01)
# Local: nSelf Redis at redis://localhost:6379 (via nself start)
REDIS_URL=redis://localhost:6379

# Monitoring — Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=ummeco
SENTRY_PROJECT=chatislam-web

# Monitoring — Umami analytics (D-P3-21)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Daily token budget (SCI-04)
# Cap per authenticated user per day. Default: 50000 tokens (~$0.15 at Sonnet pricing).
CHAT_DAILY_TOKEN_CAP=50000

# BYO API key encryption (SCI-18) — AES-256-GCM, must be 32-byte hex (openssl rand -hex 32)
BYO_KEY_ENCRYPTION_SECRET=

# Spend alert cron (SCI-05)
# Daily spend threshold in USD — cron alerts if estimated spend exceeds this.
SPEND_ALERT_THRESHOLD_USD=5.00
# Email address to send spend alerts to (admin)
ALERT_EMAIL=aric.camarata@gmail.com
# Vercel cron security secret — must match CRON_SECRET set in Vercel project env.
# Vercel automatically sends this as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
# Hasura admin endpoint for server-side cron queries (never expose to browser)
HASURA_ENDPOINT=https://api.ummat.dev/v1/graphql
HASURA_ADMIN_SECRET=

# Widget embed (SCI-16)
# Comma-separated list of allowed parent origins (no trailing slash)
WIDGET_ALLOWED_ORIGINS=https://ummat.app
